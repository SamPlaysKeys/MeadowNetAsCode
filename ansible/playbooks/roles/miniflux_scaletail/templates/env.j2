# Environment variables required for miniflux
# The workflow will look up secrets using the naming convention:
#   1. First tries: MINIFLUX_<VARNAME> (service-specific)
#   2. Falls back to: <VARNAME> (shared secret)
#
# Example: POSTGRES_USER -> tries MINIFLUX_POSTGRES_USER, then POSTGRES_USER

TS_AUTHKEY={{ vault_ts_authkey }}
POSTGRES_USER={{ vault_miniflux_postgres_user }}
POSTGRES_PASSWORD={{ vault_miniflux_postgres_password }}
ADMIN_USERNAME={{ vault_miniflux_admin_username }}
ADMIN_PASSWORD={{ vault_miniflux_admin_password }}
BASE_URL={{ vault_miniflux_base_url }}
